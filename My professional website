<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sanskar Srivastava — Web Design Services</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:     #1A6BFF;
      --blue-dk:  #0D4FCC;
      --orange:   #FF6B1A;
      --orange-lt:#FF8C42;
      --ink:      #0B1120;
      --paper:    #F5F7FF;
      --mid:      #6271A0;
      --border:   #DDE3F5;
      --card:     #FFFFFF;
      --grad:     linear-gradient(135deg, #1A6BFF 0%, #FF6B1A 100%);
      --grad-soft:linear-gradient(135deg, #EEF3FF 0%, #FFF3EC 100%);
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--paper);
      color: var(--ink);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 5%;
      background: rgba(245,247,255,0.93);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-size: 1.25rem; font-weight: 800;
      letter-spacing: -0.03em; color: var(--ink);
      text-decoration: none;
    }
    .nav-logo span {
      background: var(--grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
    }
    nav ul { list-style: none; display: flex; gap: 32px; }
    nav ul a {
      text-decoration: none; font-size: 0.9rem;
      font-weight: 500; color: var(--mid); transition: color .2s;
    }
    nav ul a:hover { color: var(--ink); }
    .nav-cta {
      background: var(--grad); color: #fff !important;
      padding: 9px 22px; border-radius: 100px;
      font-weight: 600; font-size: 0.88rem !important;
      box-shadow: 0 4px 14px rgba(26,107,255,.3);
      transition: opacity .2s, transform .2s !important;
    }
    .nav-cta:hover { opacity: .88; transform: translateY(-1px); color: #fff !important; }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column; justify-content: center;
      padding: 120px 5% 80px;
      background: var(--paper);
      position: relative; overflow: hidden;
    }
    /* Decorative blobs */
    .hero::before {
      content: '';
      position: absolute; top: -120px; right: -100px;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(26,107,255,.12) 0%, transparent 70%);
      border-radius: 50%; pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute; bottom: -80px; left: -80px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(255,107,26,.1) 0%, transparent 70%);
      border-radius: 50%; pointer-events: none;
    }
    .hero-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center; gap: 64px;
      max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg,rgba(26,107,255,.1),rgba(255,107,26,.1));
      border: 1px solid rgba(26,107,255,.2);
      padding: 6px 16px; border-radius: 100px;
      font-size: 0.78rem; font-weight: 700; letter-spacing: .05em;
      text-transform: uppercase; margin-bottom: 24px;
      background-clip: padding-box;
    }
    .hero-badge-text {
      background: var(--grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-badge::before {
      content: ''; width: 8px; height: 8px; flex-shrink: 0;
      background: var(--orange); border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(255,107,26,.4); }
      50% { opacity: .9; transform: scale(1.1); box-shadow: 0 0 0 6px rgba(255,107,26,0); }
    }
    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.8rem, 5vw, 4.4rem);
      font-weight: 800; line-height: 1.05;
      letter-spacing: -0.03em; margin-bottom: 24px;
    }
    h1 em {
      font-style: normal;
      background: var(--grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-sub {
      font-size: 1.08rem; color: var(--mid);
      max-width: 480px; margin-bottom: 40px; line-height: 1.7;
    }
    .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--grad); color: #fff;
      padding: 14px 32px; border-radius: 100px;
      font-weight: 700; text-decoration: none; font-size: 0.95rem;
      box-shadow: 0 6px 24px rgba(26,107,255,.3);
      transition: transform .2s, box-shadow .2s;
    }
    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(255,107,26,.3); }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      border: 2px solid var(--border); color: var(--ink);
      padding: 13px 30px; border-radius: 100px;
      font-weight: 600; text-decoration: none; font-size: 0.95rem;
      transition: border-color .2s, background .2s;
    }
    .btn-secondary:hover { border-color: var(--blue); background: rgba(26,107,255,.05); }

    /* Hero visual */
    .hero-visual { position: relative; }
    .mock-browser {
      background: #fff; border-radius: 16px;
      box-shadow: 0 24px 70px rgba(26,107,255,.14), 0 4px 16px rgba(0,0,0,.06);
      overflow: hidden;
      transform: perspective(900px) rotateY(-6deg) rotateX(2deg);
      transition: transform .4s;
    }
    .mock-browser:hover { transform: perspective(900px) rotateY(-2deg) rotateX(1deg); }
    .mock-bar {
      background: #F2F4FB; padding: 10px 16px;
      display: flex; align-items: center; gap: 8px;
      border-bottom: 1px solid #E5E9F5;
    }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot.r { background: #FF5F57; }
    .dot.y { background: #FEBC2E; }
    .dot.g { background: #28C840; }
    .mock-url {
      margin-left: 12px; flex: 1;
      background: #fff; border-radius: 6px;
      padding: 4px 12px; font-size: 0.72rem; color: #888;
      border: 1px solid #E0E5F5;
    }
    .mock-body { padding: 20px 18px; }
    .mock-hero-bar {
      background: var(--grad);
      height: 54px; border-radius: 10px; margin-bottom: 14px;
      display: flex; align-items: center; padding: 0 18px;
    }
    .mock-hero-bar-text { color: #fff; font-size: 0.8rem; font-weight: 700; }
    .mock-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .mock-card {
      background: var(--paper); border-radius: 8px;
      padding: 12px; border: 1px solid var(--border);
    }
    .mock-card-icon { width: 26px; height: 26px; border-radius: 6px; margin-bottom: 8px; }
    .mock-card-line { height: 6px; background: var(--border); border-radius: 4px; margin-bottom: 4px; }
    .mock-card-line.short { width: 60%; }
    .stat-row { display: flex; gap: 10px; margin-top: 14px; }
    .stat-pill {
      flex: 1; background: var(--grad-soft);
      border-radius: 10px; padding: 12px;
      display: flex; flex-direction: column; gap: 2px;
      border: 1px solid rgba(26,107,255,.1);
    }
    .stat-num {
      font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 800;
      background: var(--grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
    }
    .stat-label { font-size: 0.68rem; color: var(--mid); font-weight: 500; }

    /* floating badge */
    .float-badge {
      position: absolute; bottom: -16px; right: -16px;
      background: #fff; border-radius: 14px; padding: 14px 18px;
      box-shadow: 0 8px 28px rgba(255,107,26,.18);
      display: flex; align-items: center; gap: 10px;
      border: 1.5px solid rgba(255,107,26,.15);
    }
    .float-badge-icon { font-size: 1.4rem; }
    .float-badge-text { display: flex; flex-direction: column; gap: 1px; }
    .float-badge-main { font-weight: 700; font-size: 0.82rem; color: var(--ink); }
    .float-badge-sub { font-size: 0.7rem; color: var(--mid); }

    /* ── SECTIONS ── */
    section { padding: 90px 5%; }
    .section-inner { max-width: 1200px; margin: 0 auto; }
    .section-tag {
      display: inline-block;
      font-size: 0.74rem; font-weight: 700; letter-spacing: .08em;
      text-transform: uppercase;
      background: var(--grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 14px;
    }
    h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.9rem, 3.5vw, 2.75rem);
      font-weight: 800; letter-spacing: -0.03em;
      line-height: 1.1; margin-bottom: 16px;
    }
    .section-sub { font-size: 1rem; color: var(--mid); max-width: 520px; line-height: 1.7; }

    /* ── SERVICES ── */
    #services {
      background: linear-gradient(160deg, #0B1B4D 0%, #1A1A2E 60%, #2D1200 100%);
      color: #fff;
    }
    #services .section-tag { background: linear-gradient(135deg,#FF8C42,#FFD700); -webkit-background-clip:text; background-clip:text; }
    #services h2 { color: #fff; }
    #services .section-sub { color: rgba(255,255,255,.5); }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 18px; margin-top: 52px;
    }
    .service-card {
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 18px; padding: 30px;
      transition: background .25s, transform .25s, border-color .25s;
      position: relative; overflow: hidden;
    }
    .service-card::before {
      content: ''; position: absolute;
      top: 0; left: 0; right: 0; height: 3px;
      background: var(--grad); opacity: 0;
      transition: opacity .3s;
    }
    .service-card:hover { background: rgba(255,255,255,.09); transform: translateY(-5px); border-color: rgba(255,255,255,.18); }
    .service-card:hover::before { opacity: 1; }
    .service-icon {
      width: 50px; height: 50px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; margin-bottom: 20px;
    }
    .service-card h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 10px;
    }
    .service-card p { font-size: 0.88rem; color: rgba(255,255,255,.48); line-height: 1.65; }

    /* ── PROCESS ── */
    .process-list { display: flex; flex-direction: column; margin-top: 52px; }
    .process-step {
      display: grid; grid-template-columns: 80px 1fr;
      gap: 24px; padding: 30px 0;
      border-bottom: 1px solid var(--border);
    }
    .process-step:last-child { border-bottom: none; }
    .step-num {
      font-family: 'Syne', sans-serif;
      font-size: 2.2rem; font-weight: 800;
      background: var(--grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
      opacity: .25; line-height: 1; padding-top: 4px;
    }
    .step-body h3 { font-family:'Syne',sans-serif; font-size:1.1rem; font-weight:700; margin-bottom:6px; }
    .step-body p { color: var(--mid); font-size: 0.9rem; }

    /* ── PRICING ── */
    #pricing { background: var(--grad-soft); }
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px; margin-top: 52px;
    }
    .pricing-card {
      background: #fff; border-radius: 22px;
      padding: 36px 32px;
      border: 1.5px solid var(--border);
      position: relative; overflow: hidden;
      transition: transform .25s, box-shadow .25s;
    }
    .pricing-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(26,107,255,.1); }
    .pricing-card.featured {
      border: 2px solid transparent;
      background: linear-gradient(#fff,#fff) padding-box, var(--grad) border-box;
      box-shadow: 0 12px 40px rgba(26,107,255,.15);
    }
    .featured-badge {
      position: absolute; top: 20px; right: 20px;
      background: var(--grad); color: #fff;
      font-size: 0.68rem; font-weight: 700;
      padding: 4px 12px; border-radius: 100px;
      letter-spacing: .04em; text-transform: uppercase;
    }
    .pricing-tier { font-size: 0.76rem; font-weight: 700; text-transform:uppercase; letter-spacing:.06em; color:var(--mid); margin-bottom:12px; }
    .pricing-price {
      font-family:'Syne',sans-serif; font-size:2.4rem; font-weight:800;
      line-height:1; margin-bottom:6px;
      background: var(--grad); -webkit-background-clip:text;
      -webkit-text-fill-color:transparent; background-clip:text;
    }
    .pricing-desc { font-size:0.88rem; color:var(--mid); margin-bottom:28px; }
    .pricing-features { list-style:none; display:flex; flex-direction:column; gap:12px; }
    .pricing-features li { display:flex; align-items:flex-start; gap:10px; font-size:0.9rem; }
    .pricing-features li::before { content:'✓'; font-weight:700; font-size:0.85rem; flex-shrink:0; margin-top:1px;
      background:var(--grad); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .pricing-cta {
      display:block; text-align:center; margin-top:32px; padding:13px;
      border-radius:100px; font-weight:600; font-size:0.9rem;
      text-decoration:none; transition:all .2s;
    }
    .pricing-cta.outline { border:1.5px solid var(--border); color:var(--ink); }
    .pricing-cta.outline:hover { border-color:var(--blue); color:var(--blue); background:rgba(26,107,255,.04); }
    .pricing-cta.filled { background:var(--grad); color:#fff; box-shadow:0 4px 16px rgba(255,107,26,.25); }
    .pricing-cta.filled:hover { opacity:.88; transform:translateY(-1px); }

    /* ── ABOUT ── */
    .about-grid {
      display:grid; grid-template-columns:1fr 1fr;
      gap:72px; align-items:center; max-width:1200px; margin:0 auto;
    }
    .about-visual {
      background: var(--grad);
      border-radius:24px; padding:40px; position:relative; overflow:hidden;
    }
    .about-visual::before {
      content:''; position:absolute; top:-60px; right:-60px;
      width:200px; height:200px;
      background:rgba(255,255,255,.1); border-radius:50%;
    }
    .about-visual::after {
      content:''; position:absolute; bottom:-40px; left:-40px;
      width:150px; height:150px;
      background:rgba(255,255,255,.08); border-radius:50%;
    }
    .about-name { font-family:'Syne',sans-serif; font-size:1.8rem; font-weight:800; color:#fff; margin-bottom:6px; position:relative; z-index:1; }
    .about-title { color:rgba(255,255,255,.75); font-weight:600; font-size:0.95rem; margin-bottom:20px; position:relative; z-index:1; }
    .about-visual > p { color:rgba(255,255,255,.7); font-size:0.9rem; position:relative; z-index:1; }
    .about-stats { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:24px; position:relative; z-index:1; }
    .about-stat { background:rgba(255,255,255,.15); backdrop-filter:blur(8px); border-radius:12px; padding:16px; border:1px solid rgba(255,255,255,.2); }
    .about-stat-num { font-family:'Syne',sans-serif; font-size:1.6rem; font-weight:800; color:#fff; line-height:1; }
    .about-stat-label { font-size:0.75rem; color:rgba(255,255,255,.65); margin-top:4px; }
    .about-content h2 { margin-bottom:20px; }
    .about-content p { color:var(--mid); font-size:0.97rem; margin-bottom:16px; line-height:1.7; }
    .skill-tags { display:flex; flex-wrap:wrap; gap:10px; margin-top:28px; }
    .skill-tag {
      padding:7px 16px; border-radius:100px;
      font-size:0.78rem; font-weight:600;
      background: var(--grad-soft);
      border:1px solid rgba(26,107,255,.15); color:var(--blue);
    }

    /* ── DELIVERY ── */
    #delivery { background: linear-gradient(160deg,#0B1B4D 0%,#1A1A2E 60%,#2D1200 100%); color:#fff; }
    #delivery h2 { color:#fff; }
    #delivery .section-tag { background:linear-gradient(135deg,#FF8C42,#FFD700); -webkit-background-clip:text; background-clip:text; }
    .delivery-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:52px; }
    .delivery-card { border-radius:18px; padding:36px; display:flex; flex-direction:column; gap:12px; }
    .delivery-card.standard { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); }
    .delivery-card.urgent { background: var(--grad); box-shadow:0 12px 40px rgba(255,107,26,.3); }
    .delivery-label { font-size:0.72rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:rgba(255,255,255,.5); }
    .delivery-card.urgent .delivery-label { color:rgba(255,255,255,.8); }
    .delivery-time { font-family:'Syne',sans-serif; font-size:2.8rem; font-weight:800; line-height:1; color:#fff; }
    .delivery-desc { font-size:0.9rem; color:rgba(255,255,255,.5); }
    .delivery-card.urgent .delivery-desc { color:rgba(255,255,255,.8); }
    .delivery-note { margin-top:32px; padding:24px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:12px; font-size:0.9rem; color:rgba(255,255,255,.5); }
    .delivery-note strong { color:#fff; }

    /* ── CONTACT ── */
    .contact-wrap { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:start; }
    .contact-info h2 { margin-bottom:16px; }
    .contact-info p { color:var(--mid); margin-bottom:40px; line-height:1.7; }
    .contact-methods { display:flex; flex-direction:column; gap:14px; }
    .contact-method {
      display:flex; align-items:center; gap:16px;
      padding:18px 22px; background:#fff;
      border:1.5px solid var(--border); border-radius:14px;
      text-decoration:none; color:var(--ink);
      transition:border-color .2s, box-shadow .2s, transform .2s;
    }
    .contact-method:hover { border-color:var(--blue); box-shadow:0 4px 18px rgba(26,107,255,.1); transform:translateX(4px); }
    .contact-method-icon {
      width:44px; height:44px; border-radius:10px;
      background:var(--grad-soft); display:flex;
      align-items:center; justify-content:center;
      font-size:1.2rem; flex-shrink:0;
    }
    .contact-method-info { display:flex; flex-direction:column; gap:2px; }
    .contact-method-label { font-size:0.72rem; color:var(--mid); font-weight:500; }
    .contact-method-value { font-weight:700; font-size:0.98rem; }
    .wa-direct-btn {
      display:flex; align-items:center; gap:14px;
      padding:18px 22px; margin-top:6px;
      background:linear-gradient(135deg,#25D366,#128C7E);
      border-radius:14px; text-decoration:none; color:#fff;
      font-weight:700; font-size:0.95rem;
      box-shadow:0 6px 20px rgba(37,211,102,.3);
      transition:transform .2s, box-shadow .2s;
    }
    .wa-direct-btn:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(37,211,102,.35); }
    .wa-direct-btn-icon { font-size:1.5rem; }

    .contact-form { display:flex; flex-direction:column; gap:14px; }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-group label { font-size:0.82rem; font-weight:600; color:var(--ink); }
    .form-group input, .form-group textarea, .form-group select {
      padding:13px 16px; border:1.5px solid var(--border); border-radius:10px;
      font-family:'Space Grotesk',sans-serif; font-size:0.93rem;
      background:#fff; color:var(--ink); transition:border-color .2s; outline:none;
    }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
      border-color:var(--blue); box-shadow:0 0 0 3px rgba(26,107,255,.1);
    }
    .form-group textarea { min-height:120px; resize:verti
